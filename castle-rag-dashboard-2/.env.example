# Index paths (defaults already point to Snellius shared scratch)
VISUAL_INDEX_DIR=/gpfs/scratch1/shared/group_h/data_goncalo/artifacts/siglip_index_day1
TRANSCRIPT_INDEX_DIR=/gpfs/scratch1/shared/group_h/data_goncalo/artifacts/transcript_index_day1

# Model paths
GROUNDING_DINO_MODEL=/gpfs/scratch1/shared/group_h/models/grounding-dino-base
GROUNDING_DINO_DEVICE=cuda
GROUNDING_DINO_LOCAL_FILES_ONLY=1

# Device for SigLIP2 text embedding
SIGLIP_DEVICE=cuda

# Optional home-local copies. When absent or incomplete, the app safely falls
# back to the shared group models/indexes.
SIGLIP_TEXT_MODEL_NAME=/gpfs/scratch1/shared/group_h/models/siglip2-so400m-patch16-512-text
MINILM_MODEL_DIR=/gpfs/scratch1/shared/group_h/models/all-MiniLM-L6-v2
ANSWER_SPAN_QA_MODEL=/gpfs/scratch1/shared/group_h/models/distilbert-base-cased-distilled-squad

# Snellius compute nodes are offline; avoid slow Hugging Face retries.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Override this to run a second dashboard without stopping an existing job.
DASH_HOST=127.0.0.1
DASH_PORT=13209

# Teammate-compatible default: MiniLM passage reranking over 50 fused
# candidates. To test BGE instead, replace "minilm" with the local BGE path.
CASTLE_USE_BGE_RERANKER=0
TRANSCRIPT_RERANKER_MODEL=minilm
TRANSCRIPT_RERANK_K=50
TRANSCRIPT_RERANK_BATCH_SIZE=8
TRANSCRIPT_RERANK_NORMALIZE=1
TRANSCRIPT_RERANK_DEVICE=cuda
